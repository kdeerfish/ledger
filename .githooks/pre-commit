#!/bin/bash
# .githooks/pre-commit
# Go 项目 pre-commit hook: 自动跑 gofmt + go vet + 单元测试
#
# 安装: make pre-commit-setup  或  git config core.hooksPath .githooks
# 跳过: git commit --no-verify (不推荐)

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🛡  Pre-commit checks"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── 1. gofmt ──────────────────────────────────────────────
echo -n "  📝 gofmt ... "
GO_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.go$' || true)
if [ -z "$GO_FILES" ]; then
    echo -e "${GREEN}skip (no .go files changed)${NC}"
else
    UNFMT=$(echo "$GO_FILES" | xargs gofmt -l 2>/dev/null || true)
    if [ -n "$UNFMT" ]; then
        echo -e "${RED}FAIL${NC}"
        echo ""
        echo "  Unformatted files:"
        for f in $UNFMT; do
            echo "    - $f"
        done
        echo ""
        echo "  Fix: gofmt -w $UNFMT"
        exit 1
    fi
    echo -e "${GREEN}pass${NC}"
fi

# ── 2. go vet ─────────────────────────────────────────────
echo -n "  🔍 go vet ... "
if go vet ./... 2>/dev/null; then
    echo -e "${GREEN}pass${NC}"
else
    echo -e "${RED}FAIL${NC}"
    echo ""
    echo "  Fix the issues above and try again."
    exit 1
fi

# ── 3. unit tests (quick, no -v) ─────────────────────────
echo -n "  ✅ go test ... "
if go test -count=1 -short ./internal/... 2>/dev/null; then
    echo -e "${GREEN}pass${NC}"
else
    echo -e "${RED}FAIL${NC}"
    echo ""
    echo "  Run: go test -v -count=1 ./internal/..."
    echo "  to see details."
    exit 1
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "  ${GREEN}All pre-commit checks passed!${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
