            "牛奶",
            "烟酒茶"
          ],
          "居家物业": [
            "日常用品",
            "房租水电",
            "维修保养",
            "柴米油盐",
            "家电家私"
          ],
          "行车交通": [
            "打车租车",
            "公共交通",
            "高铁长途"
          ],
          "服饰饰品": [
            "衣服裤子",
            "鞋帽包包",
            "居家穿着"
          ],
          "医疗保健": [
            "药品费"
          ],
          "休闲娱乐": [
            "数码3C",
            "运动装备"
          ],
          "交流通讯": [
            "网费",
            "手机费"
          ],
          "学习进修": [
            "学无止境"
          ],
          "人情往来": [
            "礼尚往来",
            "网络红包"
          ],
          "金融保险": [
            "保险"
          ],
          "自由职业": [
            "大模型费用"
          ],
          "外贸电商": [
            "设备",
            "运费",
            "进货"
          ],
          "项目投入": [
            "批发矿泉水",
            "生意投入"
          ],
          "职业收入": [
            "卖水收入"
          ],
          "其他收入": [
            "意外来钱",
            "薅羊毛"
          ]
        }
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "账户",
        "examples": [
          "微信零钱",
          "支付宝",
          "招商银行",
          "xxx信用卡"
        ]
      },
      "project": {
        "type": "string",
        "required": false,
        "description": "项目",
        "examples": [
          "个人项目",
          "工作项目"
        ]
      },
      "member": {
        "type": "string",
        "required": false,
        "description": "成员",
        "values": [
          "本人",
          "fish",
          "妈妈",
          "家庭公用"
        ],
        "examples": [
          "本人",
          "fish"
        ]
      },
      "merchant": {
        "type": "string",
        "required": false,
        "description": "商家",
        "examples": [
          "拼多多",
          "滴滴",
          "食堂",
          "水果店"
        ]
      },
      "note": {
        "type": "string",
        "required": false,
        "description": "备注",
        "examples": [
          "零食",
          "打车",
          "6月工资"
        ]
      },
      "date": {
        "type": "string",
        "required": false,
        "description": "日期 (YYYY-MM-DD HH:MM:SS)，默认当前时间",
        "examples": [
          "2026-06-15 10:00:00",
          "2026-06-15"
        ]
      }
    }
  },
  "record_templates": {
    "description": "通用记录模板表",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "模板名称",
        "examples": [
          "零食模板",
          "午餐模板",
          "工资模板"
        ]
      },
      "template_type": {
        "type": "string",
        "required": true,
        "description": "模板类型",
        "values": [
          "支出",
          "收入",
          "预算",
          "通用"
        ],
        "default": "通用"
      },
      "type": {
        "type": "string",
        "required": false,
        "description": "交易类型",
        "values": [
          "收入",
          "支出"
        ]
      },
      "amount": {
        "type": "number",
        "required": false,
        "description": "金额",
        "default": 0
      },
      "category": {
        "type": "string",
        "required": false,
        "description": "类别"
      },
      "subcategory": {
        "type": "string",
        "required": false,
        "description": "子类别"
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "账户"
      },
      "project": {
        "type": "string",
        "required": false,
        "description": "项目"
      },
      "member": {
        "type": "string",
        "required": false,
        "description": "成员"
      },
      "merchant": {
        "type": "string",
        "required": false,
        "description": "商家"
      },
      "note": {
        "type": "string",
        "required": false,
        "description": "备注"
      },
      "description": {
        "type": "string",
        "required": false,
        "description": "模板描述"
      }
    }
  },
  "budgets": {
    "description": "预算表",
    "fields": {
      "category": {
        "type": "string",
        "required": true,
        "description": "预算类别"
      },
      "amount": {
        "type": "number",
        "required": true,
        "description": "预算金额"
      },
      "year": {
        "type": "integer",
        "required": false,
        "description": "年份，默认当前年"
      },
      "month": {
        "type": "integer",
        "required": false,
        "description": "月份，默认当前月"
      },
      "dimension_type": {
        "type": "string",
        "required": false,
        "description": "维度类型",
        "values": [
          "category",
          "account",
          "member",
          "project",
          "merchant"
        ],
        "default": "category"
      },
      "dimension_value": {
        "type": "string",
        "required": false,
        "description": "维度值"
      }
    }
  },
  "commands": {
    "description": "CLI 命令说明",
    "add": {
      "description": "添加交易记录",
      "required_params": [
        "type",
        "amount",
        "category"
      ],
      "optional_params": [
        "subcategory",
        "account",
        "project",
        "member",
        "merchant",
        "note",
        "date",
        "force"
      ],
      "example": "add '{\"type\":\"支出\",\"amount\":30,\"category\":\"食品酒水\",\"subcategory\":\"零食\",\"account\":\"微信零钱\"}'"
    },
    "list": {
      "description": "列出交易记录",
      "params": [
        "limit",
        "include_deleted"
      ]
    },
    "search": {
      "description": "搜索交易记录",
      "required_params": [
        "keyword"
      ],
      "params": [
        "search_type",
        "limit"
      ]
    },
    "filter": {
      "description": "筛选交易记录",
      "params": [
        "category",
        "account",
        "member",
        "merchant",
        "project",
        "start_date",
        "end_date",
        "limit"
      ]
    },
    "summary": {
      "description": "收支汇总",
      "params": [
        "year",
        "month"
      ]
    },
    "stats": {
      "description": "统计分析",
      "params": [
        "year",
        "month",
        "group_by"
      ]
    },
    "template_create": {
      "description": "创建记录模板",
      "required_params": [
        "name"
      ],
      "params": [
        "template_type",
        "type",
        "amount",
        "category",
        "subcategory",
        "account",
        "project",
        "member",
        "merchant",
        "note",
        "description"
      ]
    },
    "template_list": {
      "description": "列出模板",
      "params": [
        "template_type"
      ]
    },
    "template_apply": {
      "description": "应用模板",
      "required_params": [
        "id"
      ],
      "params": [
        "amount"
      ]
    },
    "template_suggest": {
      "description": "推荐模板",
      "params": [
        "limit"
      ]
    },
    "analyze": {
      "description": "分析用户数据，输出结构化摘要供 agent 学习",
      "params": [],
      "output": "包含账户、商家、类别、成员、项目、交叉关联、字段使用率等分析报告"
    }
  },
  "members": {
    "description": "成员说明 - 请通过 analyze 命令从用户数据中自动获取",
    "reference": "运行 analyze 命令查看用户的实际成员列表"
  },
  "field_guide": {
    "description": "字段用途说明 - 记账时必须正确区分每个字段",
    "rules": {
      "account": {
        "meaning": "账户 = 付款方式/资金来源",
        "judgment": "钱从哪里扣/收到哪里",
        "examples": [
          "微信零钱",
          "支付宝",
          "招商银行",
          "xxx信用卡"
        ],
        "common_mistake": "❌ 把'京东'当账户"
      },
      "merchant": {
        "meaning": "商家 = 消费场所/平台",
        "judgment": "在哪里花的钱",
        "examples": [
          "京东",
          "拼多多",
          "美团",
          "滴滴",
          "饿了么"
        ],
        "common_mistake": "❌ 把'微信'当商家"
      },
      "category": {
        "meaning": "类别 = 花在什么类型的东西上",
        "judgment": "消费的类型",
        "examples": [
          "食品酒水",
          "交通",
          "服饰",
          "居家物业"
        ],
        "common_mistake": "❌ 把'零食'当类别"
      },
      "subcategory": {
        "meaning": "子类别 = 具体花在什么上",
        "judgment": "类别下的细分",
        "examples": [
          "零食",
          "早午餐",
          "水果",
          "打车租车"
        ],
        "common_mistake": "❌ 把'食品酒水'当子类别"
      },
      "project": {
        "meaning": "项目 = 归属的长期项目/生意",
        "judgment": "不是商家！是你的项目",
        "examples": [
          "电商",
          "AI",
          "外贸",
          "批发生意"
        ],
        "common_mistake": "❌ 把'拼多多'当项目"
      },
      "member": {
        "meaning": "成员 = 谁花了这笔钱",
        "judgment": "谁的消费",
        "examples": [
          "本人",
          "fish",
          "妈妈",
          "家庭公用"
        ],
        "common_mistake": ""
      }
    },
    "when_uncertain": [
      "1. 查记忆：参考之前'学习'保存的用户习惯",
      "2. 查数据：运行 analyze 查看用户的实际数据分布",
      "3. 问用户：不确定就问'这个应该填在哪里？'"
    ]
  }
}