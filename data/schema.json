{
  "version": "1.0.0",
  "description": "Ledger 记账系统字段定义 - Agent 可读取此文件了解字段含义和合法值",
  "transactions": {
    "description": "交易记录表",
    "fields": {
      "type": {
        "type": "string",
        "required": true,
        "description": "交易类型",
        "values": [
          "收入",
          "支出"
        ],
        "examples": [
          "收入",
          "支出"
        ]
      },
      "amount": {
        "type": "number",
        "required": true,
        "description": "金额",
        "min": 0,
        "examples": [
          25.5,
          100,
          5000
        ]
      },
      "category": {
        "type": "string",
        "required": true,
        "description": "类别",
        "values": {
          "支出": [
            "食品酒水",
            "居家物业",
            "行车交通",
            "服饰饰品",
