{
  "version": "1.0.0",
  "description": "Ledger 记账系统字段定义 - Agent 可读取此文件了解字段含义和合法值",
  
  "transactions": {
    "description": "交易记录表",
    "fields": {
      "type": {
        "type": "string",
        "required": true,
        "description": "交易类型",
        "values": ["收入", "支出"],
        "examples": ["收入", "支出"]
      },
      "amount": {
        "type": "number",
        "required": true,
        "description": "金额",
        "min": 0,
        "examples": [25.5, 100, 5000]
      },
      "category": {
        "type": "string",
        "required": true,
        "description": "类别",
        "values": {
          "支出": [
            "食品酒水", "居家物业", "行车交通", "服饰饰品", 
            "医疗保健", "休闲娱乐", "交流通讯", "学习进修",
            "人情往来", "其他杂项", "金融保险", "自由职业",
            "外贸电商", "项目投入"
          ],
          "收入": ["职业收入", "其他收入"]
        },
        "examples": ["食品酒水", "交通", "工资"]
      },
      "subcategory": {
        "type": "string",
        "required": false,
        "description": "子类别",
        "examples": {
          "食品酒水": ["零食", "早午晚餐", "水果", "饮料", "甜品", "牛奶", "烟酒茶"],
          "居家物业": ["日常用品", "房租水电", "维修保养", "柴米油盐", "家电家私"],
          "行车交通": ["打车租车", "公共交通", "高铁长途"],
          "服饰饰品": ["衣服裤子", "鞋帽包包", "居家穿着"],
          "医疗保健": ["药品费"],
          "休闲娱乐": ["数码3C", "运动装备"],
          "交流通讯": ["网费", "手机费"],
          "学习进修": ["学无止境"],
          "人情往来": ["礼尚往来", "网络红包"],
          "金融保险": ["保险"],
          "自由职业": ["大模型费用"],
          "外贸电商": ["设备", "运费", "进货"],
          "项目投入": ["批发矿泉水", "生意投入"],
          "职业收入": ["卖水收入"],
          "其他收入": ["意外来钱", "薅羊毛"]
        }
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "账户",
        "examples": ["微信零钱", "支付宝", "招商银行", "xxx信用卡"]
      },
      "project": {
        "type": "string",
        "required": false,
        "description": "项目",
        "examples": ["个人项目", "工作项目"]
      },
      "member": {
        "type": "string",
        "required": false,
        "description": "成员",
        "values": ["本人", "fish", "妈妈", "家庭公用"],
        "examples": ["本人", "fish"]
      },
      "merchant": {
        "type": "string",
        "required": false,
        "description": "商家",
        "examples": ["拼多多", "滴滴", "食堂", "水果店"]
      },
      "note": {
        "type": "string",
        "required": false,
        "description": "备注",
        "examples": ["零食", "打车", "6月工资"]
      },
      "date": {
        "type": "string",
        "required": false,
        "description": "日期 (YYYY-MM-DD HH:MM:SS)，默认当前时间",
        "examples": ["2026-06-15 10:00:00", "2026-06-15"]
      }
    }
  },

  "record_templates": {
    "description": "通用记录模板表",
    "fields": {
      "name": {
        "type": "string",
        "required": true,
        "description": "模板名称",
        "examples": ["零食模板", "午餐模板", "工资模板"]
      },
      "template_type": {
        "type": "string",
        "required": true,
        "description": "模板类型",
        "values": ["支出", "收入", "预算", "通用"],
        "default": "通用"
      },
      "type": {
        "type": "string",
        "required": false,
        "description": "交易类型",
        "values": ["收入", "支出"]
      },
      "amount": {
        "type": "number",
        "required": false,
        "description": "金额",
        "default": 0
      },
      "category": {
        "type": "string",
        "required": false,
        "description": "类别"
      },
      "subcategory": {
        "type": "string",
        "required": false,
        "description": "子类别"
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "账户"
      },
      "project": {
        "type": "string",
        "required": false,
        "description": "项目"
      },
      "member": {
        "type": "string",
        "required": false,
        "description": "成员"
      },
      "merchant": {
        "type": "string",
        "required": false,
        "description": "商家"
      },
      "note": {
        "type": "string",
        "required": false,
        "description": "备注"
      },
      "description": {
        "type": "string",
        "required": false,
        "description": "模板描述"
      }
    }
  },

  "budgets": {
    "description": "预算表",
    "fields": {
      "category": {
        "type": "string",
        "required": true,
        "description": "预算类别"
      },
      "amount": {
        "type": "number",
        "required": true,
        "description": "预算金额"
      },
      "year": {
        "type": "integer",
        "required": false,
        "description": "年份，默认当前年"
      },
      "month": {
        "type": "integer",
        "required": false,
        "description": "月份，默认当前月"
      },
      "dimension_type": {
        "type": "string",
        "required": false,
        "description": "维度类型",
        "values": ["category", "account", "member", "project", "merchant"],
        "default": "category"
      },
      "dimension_value": {
        "type": "string",
        "required": false,
        "description": "维度值"
      }
    }
  },

  "commands": {
    "description": "CLI 命令说明",
    "add": {
      "description": "添加交易记录",
      "required_params": ["type", "amount", "category"],
      "optional_params": ["subcategory", "account", "project", "member", "merchant", "note", "date", "force"],
      "example": "add '{\"type\":\"支出\",\"amount\":30,\"category\":\"食品酒水\",\"subcategory\":\"零食\",\"account\":\"微信零钱\"}'"
    },
    "list": {
      "description": "列出交易记录",
      "params": ["limit", "include_deleted"]
    },
    "search": {
      "description": "搜索交易记录",
      "required_params": ["keyword"],
      "params": ["search_type", "limit"]
    },
    "filter": {
      "description": "筛选交易记录",
      "params": ["category", "account", "member", "merchant", "project", "start_date", "end_date", "limit"]
    },
    "summary": {
      "description": "收支汇总",
      "params": ["year", "month"]
    },
    "stats": {
      "description": "统计分析",
      "params": ["year", "month", "group_by"]
    },
    "template_create": {
      "description": "创建记录模板",
      "required_params": ["name"],
      "params": ["template_type", "type", "amount", "category", "subcategory", "account", "project", "member", "merchant", "note", "description"]
    },
    "template_list": {
      "description": "列出模板",
      "params": ["template_type"]
    },
    "template_apply": {
      "description": "应用模板",
      "required_params": ["id"],
      "params": ["amount"]
    },
    "template_suggest": {
      "description": "推荐模板",
      "params": ["limit"]
    }
  },

  "members": {
    "description": "成员说明",
    "values": {
      "本人": "用户本人",
      "fish": "用户的伴侣",
      "妈妈": "用户的母亲",
      "家庭公用": "家庭共同支出"
    }
  }
}
