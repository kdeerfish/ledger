{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "go",
      "args": ["build", "-trimpath", "-ldflags", "-s -w", "-o", "bin/ledger-cli.exe", "."],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$go"],
      "detail": "Build single binary bin/ledger-cli.exe"
    },
    {
      "label": "Package: Windows",
      "type": "shell",
      "command": "package.bat",
      "args": [],
      "group": "build",
      "problemMatcher": [],
      "detail": "Cross-compile 5 platforms + create skill zip (Windows)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Package: Linux/macOS",
      "type": "shell",
      "command": "bash",
      "args": ["package.sh"],
      "group": "build",
      "problemMatcher": [],
      "detail": "Cross-compile 5 platforms + create skill zip (Linux/macOS)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "powershell",
      "args": ["-Command", "Remove-Item -Recurse -Force bin, dist, ledger-cli.exe -ErrorAction SilentlyContinue"],
      "problemMatcher": [],
      "detail": "Remove build artifacts: bin/, dist/, ledger-cli.exe"
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "go",
      "args": ["test", "-count=1", "-v", "./..."],
      "group": "test",
      "problemMatcher": ["$go"],
      "detail": "Run all tests"
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "go",
      "args": ["fmt", "./..."],
      "problemMatcher": [],
      "detail": "gofmt -s -w"
    },
    {
      "label": "Vet",
      "type": "shell",
      "command": "go",
      "args": ["vet", "./..."],
      "problemMatcher": ["$go"],
      "detail": "go vet static check"
    },
    {
      "label": "Tidy Modules",
      "type": "shell",
      "command": "go",
      "args": ["mod", "tidy"],
      "problemMatcher": [],
      "detail": "go mod tidy"
    },
    {
      "label": "Run: --help",
      "type": "shell",
      "command": "go",
      "args": ["run", ".", "--help"],
      "problemMatcher": [],
      "detail": "Show CLI help"
    }
  ]
}
