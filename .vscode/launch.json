{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: tx add",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["tx", "add", "--type", "expense", "--amount", "25.5", "--category", "food", "--account", "wechat", "--note", "lunch"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: tx list",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["tx", "list", "--limit", "10"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: tx get",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["tx", "get", "1"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: summary",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["summary"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: stats",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["stats", "--group-by", "category"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: budget list",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["budget", "list"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: template list",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["template", "list"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: info",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["info"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: Custom",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["${input:cliArgs}"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: Current Test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}",
      "args": ["-test.run", "^${selectedText}$", "-test.v"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: All Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}",
      "args": ["-test.v", "-test.count=1"],
      "env": { "LEDGER_DB_PATH": "${workspaceFolder}/data/test.db" },
      "cwd": "${workspaceFolder}"
    }
  ],
  "inputs": [
    {
      "id": "cliArgs",
      "type": "promptString",
      "description": "CLI args (e.g. tx add --type expense --amount 25 --category food)",
      "default": "info"
    }
  ]
}
